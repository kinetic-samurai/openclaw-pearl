{
  "name": "@openclaw-pearl/openclaw-provider",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenClaw provider plugin for OpenClaw Pearl",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "providers": [
      "openclaw-pearl"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "startup": {
      "deferConfiguredChannelFullLoadUntilAfterListen": true
    }
  },
  "devDependencies": {
    "openclaw": "^2026.5.6",
    "typescript": "^5.7.3"
  }
}
